{
  "name": "scadpub",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "ScadPub publishes OpenSCAD models as static browser-based configurators.",
  "license": "MIT",
  "scripts": {
    "gen": "node scripts/gen-schema.mjs",
    "wasm": "node scripts/fetch-wasm.mjs",
    "predev": "npm run wasm && npm run gen",
    "dev": "vite",
    "prebuild": "npm run wasm && npm run gen",
    "build": "tsc -b && vite build",
    "preview": "npm run build && wrangler dev",
    "pretest": "npm run gen",
    "test": "node --import ./tests/register-ts.mjs --test \"tests/*.test.mjs\"",
    "smoke": "node scripts/smoke.mjs",
    "vis": "node scripts/screenshots.mjs",
    "screens": "node scripts/capture-screens.mjs",
    "lint": "eslint .",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.2",
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@xmldom/xmldom": "^0.9.10",
    "axe-core": "^4.12.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "fflate": "^0.8.3",
    "globals": "^17.7.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "wrangler": "^4.105.0"
  }
}
