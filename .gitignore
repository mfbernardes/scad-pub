# Node deps & build output
node_modules/
dist/

# Large vendored WASM binary + glue — fetched via scripts/fetch-wasm.mjs
public/wasm/

# Generated from the configured design source via scripts/gen-schema.mjs
public/scad/
src/generated/
# fontconfig config is generated (carries the optional fontFallback rule)
public/fonts/fonts.conf

# Render outputs
*.stl

# Visual-regression diff output (baselines live in tests/screenshots/, tracked)
/screenshots/

# TypeScript incremental build info
*.tsbuildinfo

# Generated PWA assets (from the active config via gen-schema)
public/manifest.webmanifest
public/icon.svg
public/icon-180.png
public/icon-192.png
public/icon-512.png
public/icon-512-maskable.png
public/apple-splash-*.png
public/precache-manifest.json

# Ownership manifest for generated files outside public/scad/ (fonts copied
# from source, PWA root assets) — scripts/lib/destinations.mjs uses it to
# clean up files a removed/renamed config entry left behind (M8).
/.gen-manifest.json
public/.gen-manifest.json

# Playwright artifacts (if a contributor runs `playwright test`)
/test-results/
/playwright-report/

# Local env overrides (Vite reads .env*; *.local stays out of git)
*.local
.env*.local

# Logs
*.log
npm-debug.log*

# Editor / OS cruft
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.sw?

# Claude
.claude/settings.local.json

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example
