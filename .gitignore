# Node deps & build output
node_modules/
dist/
# Wave 3's guided-mode smoke build (scripts/smoke-guided.mjs), a throwaway
# second build output alongside dist/ — never committed, same as dist/.
dist-guided/
# Round-5 final wave's isolated heavy-design check (checkHeavyDesignLivePreview)
# — a THIRD, equally throwaway build so marking `tag` heavy never leaks into
# the main guided suite's own dist-guided/ above.
dist-guided-heavy/
# Generated at runtime by scripts/smoke-guided.mjs's buildGuidedConfig() —
# a small explicit override on top of scadpub.config.json, never hand-edited
# or committed (was previously a hand-maintained static file tracked in git;
# now generated fresh on every smoke run so it can't drift from the config
# it forks).
scadpub.guided.generated.json
# Same story as scadpub.guided.generated.json, for buildGuidedHeavyConfig().
scadpub.guided-heavy.generated.json

# Large vendored WASM binary + glue — fetched via scripts/fetch-wasm.mjs
public/wasm/

# Generated from the configured design source via scripts/gen-schema.mjs
public/scad/
src/generated/
# fontconfig config is generated (carries the optional fontFallback rule)
public/fonts/fonts.conf

# Render outputs
*.stl

# Visual-regression diff output (baselines live in tests/screenshots/, tracked)
/screenshots/

# TypeScript incremental build info
*.tsbuildinfo

# Generated PWA assets (from the active config via gen-schema)
public/manifest.webmanifest
public/icon.svg
public/icon-180.png
public/icon-192.png
public/icon-512.png
public/icon-512-maskable.png
public/apple-splash-*.png
public/precache-manifest.json

# Ownership manifest for generated files outside public/scad/ (fonts copied
# from source, PWA root assets) — scripts/lib/destinations.mjs uses it to
# clean up files a removed/renamed config entry left behind (M8).
/.gen-manifest.json
public/.gen-manifest.json

# Playwright artifacts (if a contributor runs `playwright test`)
/test-results/
/playwright-report/

# Local env overrides (Vite reads .env*; *.local stays out of git)
*.local
.env*.local

# Logs
*.log
npm-debug.log*

# Editor / OS cruft
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.sw?

# Claude
.claude/settings.local.json

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example
